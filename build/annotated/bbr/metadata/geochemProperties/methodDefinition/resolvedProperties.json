,"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:dateModified"],"description":"ISO 8601 date of last update to this definition.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:measurementTechnique"],"description":"The analytical technique this method implements. Must be a DefinedTerm from a controlled vocabulary of techniques.","required":true,"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:measurementTechnique","schema:name"],"description":"text label for the term that is useful to human user","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:measurementTechnique","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:measurementTechnique","schema:inDefinedTermSet"],"description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:measurementTechnique","schema:termCode"],"description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:instrument"],"description":"Instrument requirements/specification for this method.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:instrument","schema:additionalType"],"description":"Domain-specific type classifications. Should include a scientific instrument type URI (e.g. wd:Q3099911 for Wikidata scientific instrument).","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:name"],"description":"Human-readable name for this instrument.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:description"],"description":"Text description of this instrument, its purpose, and capabilities.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:alternateName"],"description":"Alternate name(s), e.g. specific make/model designation, common abbreviation.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:identifier"],"description":"Formal identifier(s) for this instrument. Use PropertyValue for structured identifiers (e.g. PIDINST, serial number, inventory number).","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:url"],"description":"Landing page URL for this instrument.","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:manufacturer"],"description":"Organization that manufactured this instrument.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"],"ref":"0"},{"path":["schema:instrument","schema:model"],"description":"Product model information for this instrument.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:model","schema:name"],"description":"Model name or number.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:model","schema:identifier"],"description":"Model identifier.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:category"],"description":"Instrument type classification(s) from a controlled vocabulary.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:owner"],"description":"Organization that owns this instrument.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"],"ref":"0"},{"path":["schema:instrument","schema:contributor"],"description":"Agents associated with this instrument in specific roles (e.g. operator, custodian, principal investigator). Use schema:owner for the owning organization.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:contributor","schema:roleName"],"required":true,"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.agentInRole"]},{"path":["schema:instrument","schema:contributor","schema:contributor"],"required":true,"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.agentInRole"]},{"path":["schema:instrument","schema:additionalProperty"],"description":"Instrument-specific properties (measured variables, detection limits, calibration information, operating parameters, etc.).","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:additionalProperty","schema:propertyID"],"description":"identifier or name for the property concept quantified by the values in this variable slot. Multiple values can specify the property at different levels of granularity.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:instrument","schema:additionalProperty","schema:name"],"required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:instrument","schema:additionalProperty","schema:value"],"required":true,"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:instrument","schema:additionalProperty","schema:unitCode"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:instrument","schema:additionalProperty","schema:unitText"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:instrument","schema:validFrom"],"description":"Date the instrument was commissioned (ISO 8601).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:validThrough"],"description":"Date the instrument was decommissioned (ISO 8601). Absent if still operational.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart"],"description":"Sub-components of this instrument system. Each item is either an inline instrument description or an @id reference.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:relatedLink"],"description":"Links to related resources (manuals, datasheets, calibration records, related instruments).","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:relatedLink","schema:name"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:instrument","schema:relatedLink","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:instrument","schema:relatedLink","schema:url"],"required":true,"schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:instrument","schema:subjectOf"],"description":"Catalog record metadata-about-metadata for this instrument description.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:subjectOf","schema:dateModified"],"description":"Date this metadata record was last modified (ISO 8601).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:subjectOf","schema:about"],"schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:subjectOf","dcterms:conformsTo"],"description":"Schema or profile this metadata record conforms to.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["ada:laboratory"],"description":"Laboratory where this method was developed. Optional; omit for methods that are instrument-generic.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:laboratory","schema:additionalType"],"description":"Domain-specific type classifications for this place (e.g. facility type,laboratory classification, feature type).","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:name"],"description":"A place name for the location, either as a string or a DefinedTerm from a gazetteer.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:identifier"],"description":"Formal identifier for this place (e.g. ROR identifier for a facility).","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:alternateName"],"description":"Alternate or abbreviated name(s) for this place.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:geo"],"description":"Either a bounding box or a point location.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:geo","_anyOf"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"],"keyword":"anyOf"},{"path":["ada:laboratory","schema:geo","_anyOf","0"],"title":"a","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"],"keyword":"branch"},{"path":["ada:laboratory","schema:geo","_anyOf","0","schema:latitude"],"required":true,"schema_type":"number","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:geo","_anyOf","0","schema:longitude"],"required":true,"schema_type":"number","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:geo","_anyOf","1"],"title":"b","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"],"keyword":"branch"},{"path":["ada:laboratory","schema:geo","_anyOf","1","schema:box"],"description":"A GeoShape box defines an area on the surface of the earth defined by point locations of the southwest corner and northeast corner of the rectangle in latitude-longitude coordinates. A space should be used to separate the latitude and longitude values. The two corner coordinate points are separated by a space. 'East longitude' means positive longitude values are east of the prime (Greenwich) meridian.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:geo","_anyOf","2"],"title":"c","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"],"keyword":"branch"},{"path":["ada:laboratory","schema:geo","_anyOf","2","schema:line"],"description":"A GeoShape box defines a curvilinear geometry as a string of latitude-longitude coordinates. A space should be used to separate the latitude and longitude values. The coordinate point pairs are also separated by a space. 'East longitude' means positive longitude values are east of the prime (Greenwich) meridian. e.g. '39.33 120.77 40.44 123.96 41.00 121.34' ","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","geosparql:hasGeometry"],"description":"Optional geographic extent using wkt geometry, see Ocean InfoHub (https://book.oceaninfohub.org/thematics/spatial/README.html#simple-geosparql-wkt). Other geometry schemes might be specified in a specific domain profile, e.g. for atmospheric, subsurface data, or local coordinate systems. NOTE that the location specified here should be the same as the schema.org point or contained within the specified bounding box.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","geosparql:hasGeometry","geosparql:asWKT"],"schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","geosparql:hasGeometry","geosparql:crs"],"schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:methodParameters"],"description":"All operating, processing, and quality parameters for this method. Each parameter carries a scope tag (constant / default / optional) that controls form rendering behaviour.","required":true,"schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","schema:name"],"description":"Machine-readable parameter name (e.g. \"acceleratingVoltage\").","required":true,"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","schema:alternateName"],"description":"Human-readable display label (e.g. \"Accelerating Voltage\").","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","schema:description"],"description":"Guidance text shown to the user in the form.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","ada:scope"],"description":"constant = fixed for every session, shown as read-only. default = required, editable, pre-filled with default value. optional = available but not shown unless user adds it.","required":true,"schema_type":"string","enum":["constant","default","optional"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","ada:category"],"description":"Grouping label for form layout (e.g. \"Beam Conditions\", \"Data Processing\", \"Quality Control\").","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","schema:value"],"description":"The constant value (scope=constant) or the default value (scope=default). Type matches ada:dataType.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","ada:dataType"],"description":"Expected data type for the parameter value.","required":true,"schema_type":"string","enum":["string","number","integer","boolean","date","uri"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","schema:minValue"],"description":"Minimum allowed numeric value (scope=default only).","schema_type":"number","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","schema:maxValue"],"description":"Maximum allowed numeric value (scope=default only).","schema_type":"number","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","ada:enumeration"],"description":"Allowed values list. If present, the form renders a dropdown/select instead of free text.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","schema:unitText"],"description":"Unit of measure label (e.g. \"kV\", \"nA\", \"um\").","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","schema:unitCode"],"description":"URI for unit of measure (QUDT preferred).","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","ada:cdifPropertyPath"],"description":"The CDIF building block property path this parameter maps to (e.g. \"cdifProvActivity: schema:additionalProperty\"). Used for JSON-LD serialisation.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:methodParameters","ada:tier"],"description":"Mandatory / Recommended / Optional tier from the metadata profile. Informs validation strictness.","schema_type":"string","enum":["M","R","O"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate"],"description":"Template for per-analyte (element-specific) parameters. Defines the columns that appear in the element table, each with scope, datatype, and constraints. Analyte rows become schema:variableMeasured entries in metadata records.","schema_type":"object","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns"],"required":true,"schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:name"],"description":"Column identifier (e.g. \"diffractingCrystal\").","required":true,"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:alternateName"],"description":"Display label (e.g. \"Diffracting Crystal\").","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:description"],"description":"Guidance text.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","ada:scope"],"required":true,"schema_type":"string","enum":["constant","default","optional"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","ada:dataType"],"required":true,"schema_type":"string","enum":["string","number","integer","boolean","date","uri"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","ada:enumeration"],"schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:unitText"],"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","ada:tier"],"schema_type":"string","enum":["M","R","O"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","ada:cdifPropertyPath"],"description":"How this column maps into the variableMeasured JSON-LD structure (e.g. \"schema:additionalProperty\", \"schema:measurementTechnique\").","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:defaultAnalytes"],"description":"Pre-populated analyte rows for this method. Each entry is an object keyed by analyteColumn names.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:creator"],"description":"Person(s) who defined this method.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:relatedLink"],"description":"Publications, Zenodo records, or other references documenting this method.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:relatedLink","schema:name"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:relatedLink","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:relatedLink","schema:url"],"required":true,"schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:funding"],"schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:funding","schema:identifier"],"description":"identifier for a particular grant","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.monetaryGrant"]},{"path":["schema:funding","schema:description"],"description":"description of the funding or grant","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.monetaryGrant"]},{"path":["schema:funding","schema:name"],"description":"title of the grant","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.monetaryGrant"]},{"path":["schema:funding","schema:funder"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.monetaryGrant"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:sameAs"],"description":"other identifiers for the person","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:contactPoint"],"description":"restrict to email only. Schema.org allows telephone and postal contacts as well","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:contactPoint","schema:email"],"required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:affiliation"],"description":"if affiliation is present, value must be a schema:Organization.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:alternateName"],"description":"other labels by which the person might be known","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:identifier"],"description":"identifier for person, recommend ORCID","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:name"],"description":"string label for person that is meaningful for human users, should format consistently. Recommend 'Family Name, Given name' format.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:hasPart","schema:model"],"schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:model","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:model","schema:name"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:manufacturer"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:additionalProperty"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:additionalType"],"description":"Component type classification.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:alternateName"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:name"],"required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:identifier","schema:url"],"description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:identifier","schema:value"],"description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:identifier","schema:propertyID"],"description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:creator","schema:sameAs"],"description":"other identifiers for the person","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:creator","schema:contactPoint"],"description":"restrict to email only. Schema.org allows telephone and postal contacts as well","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:creator","schema:contactPoint","schema:email"],"required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:creator","schema:affiliation"],"description":"if affiliation is present, value must be a schema:Organization.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:creator","schema:alternateName"],"description":"other labels by which the person might be known","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:creator","schema:identifier"],"description":"identifier for person, recommend ORCID","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:creator","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:creator","schema:name"],"description":"string label for person that is meaningful for human users, should format consistently. Recommend 'Family Name, Given name' format.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]}]}