          "@id": "https://vocab.onegeochemistry.org/epma/diffracting-crystals"
        },
        "ada:dataType": "string",
        "schema:valueRequired": true,
        "ada:enumeration": ["LIF", "LIFH", "LiF", "PET", "PETJ", "TAP"],
