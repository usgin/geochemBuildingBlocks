{"defs":{"0":[{"path":["schema:additionalType"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:alternateName"],"description":"other labels by which the organization might be known","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:identifier"],"description":"identifier for organization","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:name"],"description":"string label for organization that is meaningful for human users","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:sameAs"],"description":"other identifiers for the organization","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]}],"1":[{"path":["ada:toolRole"],"description":"Role this software plays in the analytical workflow.","schema_type":"string","enum":["acquisition","reduction","processing","visualization"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:description"],"description":"Role or purpose of this tool in the method.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:name"],"description":"Name of the software (e.g. \"Probe for EPMA\").","required":true,"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:url"],"description":"URL to the software product or documentation.","schema_type":"string","format":"uri","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:version"],"description":"Software version string (e.g. \"12.9.5\").","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]}],"2":[{"path":["ada:reagentRole"],"description":"Role of this material in the method.","schema_type":"string","enum":["primaryStandard","secondaryStandard","interferenceStandard","blankMaterial","coatingMaterial","reagent"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:citation"],"description":"Publication reference for the standard's accepted values.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:citation","schema:name"],"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:citation","schema:url"],"schema_type":"string","format":"uri","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:description"],"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:identifier"],"description":"Formal identifier (IGSN, catalog number, GeoReM ID).","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:identifier","schema:propertyID"],"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:identifier","schema:value"],"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:name"],"description":"Name of the material (e.g. \"San Carlos olivine\").","required":true,"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]}],"3":[{"path":["ada:category"],"description":"Grouping label for form layout (e.g. \"Beam Conditions\", \"Data Processing\", \"Quality Control\"). String for simple cases; DefinedTerm to link to a controlled vocabulary of parameter categories.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:cdifPropertyPath"],"description":"The CDIF building block property path this parameter maps to. Used for JSON-LD serialisation.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:dataType"],"description":"Expected data type for the parameter value.","required":true,"schema_type":"string","enum":["string","number","integer","boolean","date","uri"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:enumeration"],"description":"Inline list of allowed values. Fallback when no SKOS vocabulary exists yet. If inDefinedTermSet is also present, this list is ignored in favour of the vocabulary.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:fieldScope"],"description":"Whether this parameter is fixed at the method level, varies per analytical session, or is element-specific.","required":true,"schema_type":"string","enum":["method","session","element"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:tier"],"description":"Mandatory / Recommended / Optional tier from the metadata profile. Informs validation strictness.","schema_type":"string","enum":["M","R","O"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:defaultValue"],"description":"The default value for this parameter. For constant parameters (readonlyValue=true), this is the fixed value. For editable parameters, this is the pre-filled default.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:description"],"description":"Guidance text shown to the user in the form.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:inDefinedTermSet"],"description":"SKOS ConceptScheme providing the controlled vocabulary for allowed values of this parameter. When present, form renders a dropdown/select populated from the vocabulary. Can be an object reference (@id URI), a labeled link (LinkRole with name and URL), or a plain URI string.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:maxValue"],"description":"Maximum allowed numeric value. Upper bound of valid range.","schema_type":"number","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:minValue"],"description":"Minimum allowed numeric value. Defines the lower bound of a valid range at the method level; specific values within this range may be set per element in the analyteTemplate.","schema_type":"number","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:multipleValues"],"description":"Whether multiple values are allowed (default false).","schema_type":"boolean","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:name"],"description":"Human-readable display label (e.g. \"Accelerating Voltage\").","required":true,"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:propertyID"],"description":"URI identifying this parameter type in a formal vocabulary. Links to a skos:Concept or similar term definition.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:readonlyValue"],"description":"true = constant, fixed for every session (read-only in form). false = editable (default or optional depending on valueRequired).","schema_type":"boolean","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:stepValue"],"description":"Granularity expected of the value (e.g. 0.1 for nA).","schema_type":"number","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:unitCode"],"description":"URI for unit of measure (QUDT preferred).","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:unitText"],"description":"Unit of measure label (e.g. \"kV\", \"nA\", \"um\").","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:valueName"],"description":"Machine-readable parameter name for serialization (e.g. \"acceleratingVoltage\").","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:valuePattern"],"description":"Regex pattern for validating string values.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:valueRequired"],"description":"true = must be provided (mandatory). false = optional. Combined with readonlyValue: readonly+required = constant mandatory; !readonly+required = editable mandatory; !readonly+!required = optional.","schema_type":"boolean","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]}],"4":[{"path":["dqv:isMeasurementOf"],"description":"specify the quality measure that is reported, by name, with an ID ref, or as a Defined Term","required":true,"sources":["bblocks://cdif.bbr.metadata.qualityProperties.qualityMeasure"]},{"path":["dqv:value"],"description":"the reported result of the quality measure, either as a string or a defined term from a vocabulary","required":true,"sources":["bblocks://cdif.bbr.metadata.qualityProperties.qualityMeasure"]}]},"properties":[{"path":["schema:name"],"description":"Short descriptive name with version (e.g. \"JEOL-8530F WDS Major Element Glass v2.1\").","required":true,"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:identifier"],"description":"DOI or other persistent ID for this method definition.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:description"],"description":"Human-readable summary of the method, may be auto-generated from constant parameters at registration time.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:version"],"description":"Semantic version string (e.g. \"2.1.0\").","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:datePublished"],"description":"ISO 8601 date when this method configuration was first used.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:dateModified"],"description":"ISO 8601 date of last update to this definition.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:additionalType"],"description":"Further classification of the activity type (e.g. schema:CreateAction for a production method).","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:measurementTechnique"],"description":"The analytical technique this method implements. Must be a DefinedTerm from a controlled vocabulary of techniques.","required":true,"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:measurementTechnique","schema:name"],"description":"text label for the term that is useful to human user","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:measurementTechnique","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:measurementTechnique","schema:inDefinedTermSet"],"description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:measurementTechnique","schema:termCode"],"description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:object"],"description":"Target material(s) this method is designed to analyse (e.g. silicate glass, olivine, spinel). Modeled as DefinedTerm(s) or free text.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:instrument"],"description":"Primary instrument specification for this method. Use schema:hasPart for instrument sub-components (spectrometers, detectors).","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:instrument","schema:additionalType"],"description":"Domain-specific type classifications. Should include a scientific instrument type URI (e.g. wd:Q3099911 for Wikidata scientific instrument).","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:name"],"description":"Human-readable name for this instrument.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:description"],"description":"Text description of this instrument, its purpose, and capabilities.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:alternateName"],"description":"Alternate name(s), e.g. specific make/model designation, common abbreviation.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:identifier"],"description":"Formal identifier(s) for this instrument. Use PropertyValue for structured identifiers (e.g. PIDINST, serial number, inventory number).","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:url"],"description":"Landing page URL for this instrument.","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:manufacturer"],"description":"Organization that manufactured this instrument.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"],"ref":"0"},{"path":["schema:instrument","schema:model"],"description":"Product model information for this instrument.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:model","schema:name"],"description":"Model name or number.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:model","schema:identifier"],"description":"Model identifier.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:category"],"description":"Instrument type classification(s) from a controlled vocabulary.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:owner"],"description":"Organization that owns this instrument.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"],"ref":"0"},{"path":["schema:instrument","schema:contributor"],"description":"Agents associated with this instrument in specific roles (e.g. operator, custodian, principal investigator). Use schema:owner for the owning organization.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:contributor","schema:roleName"],"required":true,"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.agentInRole"]},{"path":["schema:instrument","schema:contributor","schema:contributor"],"required":true,"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.agentInRole"]},{"path":["schema:instrument","schema:additionalProperty"],"description":"Instrument-specific properties (measured variables, detection limits, calibration information, operating parameters, etc.).","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:additionalProperty","schema:propertyID"],"description":"identifier or name for the property concept quantified by the values in this variable slot. Multiple values can specify the property at different levels of granularity.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:instrument","schema:additionalProperty","schema:name"],"required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:instrument","schema:additionalProperty","schema:value"],"required":true,"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:instrument","schema:additionalProperty","schema:unitCode"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:instrument","schema:additionalProperty","schema:unitText"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:instrument","schema:validFrom"],"description":"Date the instrument was commissioned (ISO 8601).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:validThrough"],"description":"Date the instrument was decommissioned (ISO 8601). Absent if still operational.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart"],"description":"Sub-components of this instrument system. Each item is either an inline instrument description or an @id reference.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:relatedLink"],"description":"Links to related resources (manuals, datasheets, calibration records, related instruments).","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:relatedLink","schema:name"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:instrument","schema:relatedLink","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:instrument","schema:relatedLink","schema:url"],"required":true,"schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:instrument","schema:subjectOf"],"description":"Catalog record metadata-about-metadata for this instrument description.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:subjectOf","schema:dateModified"],"description":"Date this metadata record was last modified (ISO 8601).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:subjectOf","schema:about"],"schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:subjectOf","dcterms:conformsTo"],"description":"Schema or profile this metadata record conforms to.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["bios:computationalTool"],"description":"Software tools used for data acquisition, reduction, and processing. Each tool carries name, version, and optional URL.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"],"ref":"1"},{"path":["bios:reagent"],"description":"Reference materials, calibration standards, and chemical reagents used across this method. Reagents specific to a single workflow step should be placed on that step instead.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"],"ref":"2"},{"path":["ada:laboratory"],"description":"Laboratory where this method was developed. Optional; omit for methods that are instrument-generic.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:laboratory","schema:additionalType"],"description":"Domain-specific type classifications for this place (e.g. facility type,laboratory classification, feature type).","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:name"],"description":"A place name for the location, either as a string or a DefinedTerm from a gazetteer.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:identifier"],"description":"Formal identifier for this place (e.g. ROR identifier for a facility).","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:alternateName"],"description":"Alternate or abbreviated name(s) for this place.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:geo"],"description":"Either a bounding box or a point location.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:geo","_anyOf"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"],"keyword":"anyOf"},{"path":["ada:laboratory","schema:geo","_anyOf","0"],"title":"a","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"],"keyword":"branch"},{"path":["ada:laboratory","schema:geo","_anyOf","0","schema:latitude"],"required":true,"schema_type":"number","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:geo","_anyOf","0","schema:longitude"],"required":true,"schema_type":"number","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:geo","_anyOf","1"],"title":"b","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"],"keyword":"branch"},{"path":["ada:laboratory","schema:geo","_anyOf","1","schema:box"],"description":"A GeoShape box defines an area on the surface of the earth defined by point locations of the southwest corner and northeast corner of the rectangle in latitude-longitude coordinates. A space should be used to separate the latitude and longitude values. The two corner coordinate points are separated by a space. 'East longitude' means positive longitude values are east of the prime (Greenwich) meridian.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","schema:geo","_anyOf","2"],"title":"c","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"],"keyword":"branch"},{"path":["ada:laboratory","schema:geo","_anyOf","2","schema:line"],"description":"A GeoShape box defines a curvilinear geometry as a string of latitude-longitude coordinates. A space should be used to separate the latitude and longitude values. The coordinate point pairs are also separated by a space. 'East longitude' means positive longitude values are east of the prime (Greenwich) meridian. e.g. '39.33 120.77 40.44 123.96 41.00 121.34' ","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","geosparql:hasGeometry"],"description":"Optional geographic extent using wkt geometry, see Ocean InfoHub (https://book.oceaninfohub.org/thematics/spatial/README.html#simple-geosparql-wkt). Other geometry schemes might be specified in a specific domain profile, e.g. for atmospheric, subsurface data, or local coordinate systems. NOTE that the location specified here should be the same as the schema.org point or contained within the specified bounding box.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","geosparql:hasGeometry","geosparql:asWKT"],"schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["ada:laboratory","geosparql:hasGeometry","geosparql:crs"],"schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.spatialExtent"]},{"path":["schema:agent"],"description":"Person or organisation who defined or is responsible for this method.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:agent","_anyOf"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"],"keyword":"anyOf"},{"path":["schema:agent","_anyOf","0"],"title":"a","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"],"keyword":"branch"},{"path":["schema:agent","_anyOf","0","schema:name"],"description":"string label for person that is meaningful for human users, should format consistently. Recommend 'Family Name, Given name' format.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:agent","_anyOf","0","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:agent","_anyOf","0","schema:identifier"],"description":"identifier for person, recommend ORCID","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:agent","_anyOf","0","schema:alternateName"],"description":"other labels by which the person might be known","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:agent","_anyOf","0","schema:affiliation"],"description":"if affiliation is present, value must be a schema:Organization.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:agent","_anyOf","0","schema:contactPoint"],"description":"restrict to email only. Schema.org allows telephone and postal contacts as well","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:agent","_anyOf","0","schema:contactPoint","schema:email"],"required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:agent","_anyOf","0","schema:sameAs"],"description":"other identifiers for the person","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:agent","_anyOf","1"],"title":"b","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"],"keyword":"branch"},{"path":["schema:agent","_anyOf","1","schema:additionalType"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:agent","_anyOf","1","schema:name"],"description":"string label for organization that is meaningful for human users","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:agent","_anyOf","1","schema:alternateName"],"description":"other labels by which the organization might be known","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:agent","_anyOf","1","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:agent","_anyOf","1","schema:identifier"],"description":"identifier for organization","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:agent","_anyOf","1","schema:sameAs"],"description":"other identifiers for the organization","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:actionProcess"],"description":"The standard workflow for this method, expressed as a schema:HowTo containing an ordered sequence of workflow steps. Each step is a cdi:Activity + schema:Action describing a distinct phase (sample preparation, calibration, acquisition, data processing, quality control). Steps carry their own parameters, reagents, instruments, and sub-steps.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:name"],"description":"Name of the workflow (e.g. \"EPMA WDS analytical workflow\").","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:description"],"description":"Overview of the workflow.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:url"],"description":"URL to a published protocol document.","schema_type":"string","format":"uri","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step"],"description":"Ordered sequence of workflow steps. Each step is a cdi:Activity + schema:Action describing a distinct phase of the analytical procedure.","required":true,"schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","schema:name"],"description":"Name of this workflow step (e.g. \"Sample preparation\").","required":true,"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","schema:description"],"description":"Detailed description of what this step involves.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","schema:position"],"description":"Ordinal position in the workflow sequence (1-based).","required":true,"schema_type":"integer","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","schema:additionalType"],"description":"Further classification of this step (e.g. bios:LabProcess for wet-lab steps, schema:CreateAction for production steps).","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","schema:instrument"],"description":"Instrument or equipment used in this step.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","bios:computationalTool"],"description":"Software tools used in this step.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"],"ref":"1"},{"path":["schema:actionProcess","schema:step","bios:reagent"],"description":"Reference materials, standards, or reagents used in this step.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"],"ref":"2"},{"path":["schema:actionProcess","schema:step","prov:used"],"description":"Input entities consumed or referenced by this step (e.g. prepared sample from a prior step).","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","schema:result"],"description":"Output entity produced by this step (can be referenced as input by a subsequent step).","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","schema:object"],"description":"Reference to a prior step whose result is the input for this step (action chaining).","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","schema:additionalProperty"],"description":"Step-specific parameters (e.g. beam conditions for the acquisition step, matrix correction settings for the data processing step).","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","schema:additionalProperty","schema:name"],"required":true,"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","schema:additionalProperty","schema:value"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","schema:additionalProperty","schema:unitText"],"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","ada:methodParameters"],"description":"Step-specific method parameters with scope and tier metadata. These are parameters that belong to this particular workflow phase.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"],"ref":"3"},{"path":["schema:actionProcess","schema:step","schema:actionProcess"],"description":"Sub-workflow for this step, expressed as a nested schema:HowTo with its own ordered steps. Use for steps that have a multi-phase internal procedure (e.g. sample preparation with mount, grind, polish, coat).","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:actionProcess","schema:step","dqv:hasQualityMeasurement"],"description":"Quality measurements specific to this workflow step.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"],"ref":"4"},{"path":["ada:methodParameters"],"description":"Method-level parameters that apply across all workflow steps (e.g. method-scoped constants like matrix correction model). Step-specific parameters should be placed on the appropriate workflow step instead.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"],"ref":"3"},{"path":["ada:analyteTemplate"],"description":"Template for per-analyte (element-specific) parameters. Defines the columns that appear in the element table, each with scope, datatype, and constraints. Analyte rows become schema:variableMeasured entries in metadata records. Typically associated with the acquisition workflow step.","schema_type":"object","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns"],"required":true,"schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:name"],"description":"Human-readable column label (e.g. \"Diffracting Crystal\").","required":true,"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:valueName"],"description":"Machine-readable column identifier (e.g. \"diffractingCrystal\").","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:description"],"description":"Guidance text for this column.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:propertyID"],"description":"URI identifying this column's parameter type in a formal vocabulary.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:inDefinedTermSet"],"description":"SKOS ConceptScheme providing the controlled vocabulary for allowed values in this column.","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:defaultValue"],"description":"Default value for this column (pre-filled per row).","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:readonlyValue"],"description":"true = constant across all analytes (read-only column).","schema_type":"boolean","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:valueRequired"],"description":"true = must be provided for every analyte row.","schema_type":"boolean","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:minValue"],"schema_type":"number","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:maxValue"],"schema_type":"number","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:valuePattern"],"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","ada:dataType"],"required":true,"schema_type":"string","enum":["string","number","integer","boolean","date","uri"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","ada:enumeration"],"description":"Inline allowed values list (fallback when no SKOS vocabulary exists).","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","schema:unitText"],"schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","ada:tier"],"schema_type":"string","enum":["M","R","O"],"sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:analyteColumns","ada:cdifPropertyPath"],"description":"How this column maps into the variableMeasured JSON-LD structure.","schema_type":"string","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["ada:analyteTemplate","ada:defaultAnalytes"],"description":"Pre-populated analyte rows for this method. Each entry is an object keyed by analyteColumn names.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["dqv:hasQualityMeasurement"],"description":"Quality measurements that characterize the method's expected performance (e.g. analytical precision, accuracy, counting statistics error). Uses the CDIF qualityMeasure building block.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"],"ref":"4"},{"path":["schema:relatedLink"],"description":"Publications, Zenodo records, or other references documenting this method.","schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:relatedLink","schema:name"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:relatedLink","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:relatedLink","schema:url"],"required":true,"schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:funding"],"schema_type":"array","sources":["bblocks://ada.bbr.metadata.geochemProperties.methodDefinition"]},{"path":["schema:funding","schema:identifier"],"description":"identifier for a particular grant","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.monetaryGrant"]},{"path":["schema:funding","schema:description"],"description":"description of the funding or grant","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.monetaryGrant"]},{"path":["schema:funding","schema:name"],"description":"title of the grant","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.monetaryGrant"]},{"path":["schema:funding","schema:funder"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.monetaryGrant"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:sameAs"],"description":"other identifiers for the person","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:contactPoint"],"description":"restrict to email only. Schema.org allows telephone and postal contacts as well","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:contactPoint","schema:email"],"required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:affiliation"],"description":"if affiliation is present, value must be a schema:Organization.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:alternateName"],"description":"other labels by which the person might be known","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:identifier"],"description":"identifier for person, recommend ORCID","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:contributor","schema:contributor","schema:name"],"description":"string label for person that is meaningful for human users, should format consistently. Recommend 'Family Name, Given name' format.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:instrument","schema:hasPart","schema:model"],"schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:model","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:model","schema:name"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:manufacturer"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:additionalProperty"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:additionalType"],"description":"Component type classification.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:alternateName"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:instrument","schema:hasPart","schema:name"],"required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:identifier","schema:url"],"description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:identifier","schema:value"],"description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:identifier","schema:propertyID"],"description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:object","schema:termCode"],"description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:object","schema:inDefinedTermSet"],"description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:object","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:object","schema:name"],"description":"text label for the term that is useful to human user","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]}]}