@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:      <http://schema.org/> .
@prefix ada:         <https://ada.astromat.org/metadata/> .
@prefix bios:        <https://bioschemas.org/> .
@prefix dqv:         <http://www.w3.org/ns/dqv#> .
@prefix prov:        <http://www.w3.org/ns/prov#> .
@prefix cdi:         <http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/> .
@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@base <https://www.ogc.org/rules/template/> .

# Validates method definition nodes typed as ada:MethodDefinition.
cdifd:methodDefinitionShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX ada: <https://ada.astromat.org/metadata/>
            SELECT ?this
            WHERE {
                ?this a ada:MethodDefinition .
            }
        """ ;
    ] ;
    sh:property [
        sh:path schema:name ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:severity sh:Violation ;
        sh:message "Method definition must have a schema:name." ;
    ] ;
    sh:property [
        sh:path schema:measurementTechnique ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Method definition must specify a schema:measurementTechnique." ;
    ] ;
    sh:property [
        sh:path schema:actionProcess ;
        sh:maxCount 1 ;
        sh:severity sh:Warning ;
        sh:message "Method definition should include a schema:actionProcess workflow." ;
    ] ;
    sh:property [
        sh:path schema:version ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:severity sh:Warning ;
        sh:message "Method definition should specify a schema:version." ;
    ] ;
    sh:property [
        sh:path schema:datePublished ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:severity sh:Warning ;
        sh:message "Method definition should specify schema:datePublished." ;
    ] ;
    sh:property [
        sh:path schema:instrument ;
        sh:maxCount 1 ;
        sh:severity sh:Warning ;
        sh:message "Method definition should specify a primary instrument." ;
    ] ;
    sh:property [
        sh:path ada:analyteTemplate ;
        sh:maxCount 1 ;
        sh:severity sh:Info ;
        sh:message "Method definition may include an ada:analyteTemplate." ;
    ] ;
    sh:message "Method definition nodes (ada:MethodDefinition) must have name and technique." ;
    .
