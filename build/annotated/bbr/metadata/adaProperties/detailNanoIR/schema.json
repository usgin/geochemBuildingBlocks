{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NanoIR Instrument Detail",
  "description": "Nano-IR spectroscopy collections with phase analysis",
  "type": "object",
  "properties": {
    "@type": {
      "anyOf": [
        {
          "const": "ada:NanoIRBackground"
        }
      ]
    },
    "ada:phaseAnalyzed": {
      "$ref": "https://usgin.github.io/geochemBuildingBlocks/build/annotated/bbr/metadata/adaProperties/stringArray/schema.json"
    }
  },
  "x-jsonld-prefixes": {
    "schema": "http://schema.org/",
    "ada": "https://ada.astromat.org/metadata/"
  }
}