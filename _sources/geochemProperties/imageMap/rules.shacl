@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:      <http://schema.org/> .
@prefix ada:         <https://ada.astromat.org/metadata/> .
@prefix cdifd: <https://cdif.org/validation/0.1/shacl#> .
@base <https://www.ogc.org/rules/template/> .

# Validates image map nodes typed as ada:imageMap and schema:ImageObject.
# JSON schema requires @type and componentType.
cdifd:imageMapShape
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX ada: <https://ada.astromat.org/metadata/>
            SELECT ?this
            WHERE {
                ?this a ada:imageMap .
                ?this a <http://schema.org/ImageObject> .
            }
        """ ;
    ] ;
    sh:property [
        sh:path ada:componentType ;
        sh:minCount 1 ;
        sh:message "An image map must have a componentType." ;
    ] ;
    sh:message "Image map nodes (ada:imageMap + schema:ImageObject) should have a componentType." ;
    .
