{
  "x-defs": {
    "ada.bbr.metadata.geochemProperties.detailARGT": {
      "title": "ARGT Instrument Detail",
      "description": "ARGT (Argon) document type with phase and isotope analysis",
      "type": "object",
      "properties": {
        "@type": {
          "type": "array",
          "contains": {
            "enum": [
              "ada:ARGTDocument"
            ]
          },
          "minItems": 1
        },
        "ada:phaseAnalyzed": {
          "type": "string"
        },
        "ada:isotopeType": {
          "type": "string"
        }
      },
      "x-jsonld-prefixes": {
        "schema": "http://schema.org/",
        "ada": "https://ada.astromat.org/metadata/"
      },
      "x-schema-source": "https://usgin.github.io/geochemBuildingBlocks/build/annotated/bbr/metadata/geochemProperties/detailARGT/schema.json",
      "x-schema-version": "https://json-schema.org/draft/2020-12/schema"
    }
  },
  "title": "Document Type",
  "description": "Text or PDF/A documents providing supplemental information, typically related to calibration, instrument metadata details, analysis methods, or data representation. Typed as ada:document and schema:DigitalDocument.",
  "type": "object",
  "properties": {
    "@type": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2,
      "allOf": [
        {
          "contains": {
            "enum": [
              "ada:document"
            ]
          }
        },
        {
          "contains": {
            "enum": [
              "schema:DigitalDocument"
            ]
          }
        }
      ]
    },
    "ada:componentType": {
      "description": "One of the supplemental document types if applicable",
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "@type": {
              "enum": [
                "ada:calibrationFile",
                "ada:contextVideo",
                "ada:instrumentMetadata",
                "ada:logFile",
                "ada:methodDescription",
                "ada:peaks",
                "ada:plot",
                "ada:processingMethod",
                "ada:QRISCalibrationFile",
                "ada:report",
                "ada:samplePreparation",
                "ada:shapefile",
                "ada:worldFile"
              ]
            }
          }
        },
        {
          "$ref": "https://usgin.github.io/geochemBuildingBlocks/build/annotated/bbr/metadata/geochemProperties/document/schema-oas3.0.json#/x-defs/ada.bbr.metadata.geochemProperties.detailARGT"
        }
      ]
    },
    "schema:version": {
      "type": "string"
    },
    "schema:isBasedOn": {
      "description": "same as ada/samis '_originalName'",
      "type": "string"
    }
  },
  "required": [
    "@type",
    "ada:componentType"
  ],
  "x-jsonld-prefixes": {
    "schema": "http://schema.org/",
    "ada": "https://ada.astromat.org/metadata/"
  },
  "x-schema-version": "https://json-schema.org/draft/2020-12/schema"
}