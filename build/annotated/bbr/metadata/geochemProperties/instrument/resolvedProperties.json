{"defs":{"0":[{"path":["schema:additionalType"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:additionalType","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:additionalType","schema:inDefinedTermSet"],"description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:additionalType","schema:name"],"description":"text label for the term that is useful to human user","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:additionalType","schema:termCode"],"description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:alternateName"],"description":"other labels by which the organization might be known","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:identifier"],"description":"identifier for organization","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:name"],"description":"string label for organization that is meaningful for human users","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:sameAs"],"description":"other identifiers for the organization","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]}]},"properties":[{"path":["schema:additionalType"],"description":"Domain-specific type classifications. Should include a scientific instrument type URI (e.g. wd:Q3099911 for Wikidata scientific instrument).","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument","bblocks://ada.bbr.metadata.geochemProperties.instrument"]},{"path":["schema:name"],"description":"Human-readable name for this instrument.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:description"],"description":"Text description of this instrument, its purpose, and capabilities.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:alternateName"],"description":"Alternate name(s), e.g. specific make/model designation, common abbreviation.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:identifier"],"description":"Formal identifier(s) for this instrument. Use PropertyValue for structured identifiers (e.g. PIDINST, serial number, inventory number).","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:url"],"description":"Landing page URL for this instrument.","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:manufacturer"],"description":"Organization that manufactured this instrument.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"],"ref":"0"},{"path":["schema:model"],"description":"Product model information for this instrument.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:model","schema:name"],"description":"Model name or number.","required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:model","schema:identifier"],"description":"Model identifier.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:category"],"description":"Instrument type classification(s) from a controlled vocabulary.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:owner"],"description":"Organization that owns this instrument.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"],"ref":"0"},{"path":["schema:contributor"],"description":"Agents associated with this instrument in specific roles (e.g. operator, custodian, principal investigator). Use schema:owner for the owning organization.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:contributor","schema:roleName"],"required":true,"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.agentInRole"]},{"path":["schema:contributor","schema:contributor"],"required":true,"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.agentInRole"]},{"path":["schema:additionalProperty"],"description":"Instrument-specific properties (measured variables, detection limits, calibration information, operating parameters, etc.).","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:additionalProperty","schema:propertyID"],"description":"identifier or name for the property concept quantified by the values in this variable slot. Multiple values can specify the property at different levels of granularity.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:additionalProperty","schema:name"],"required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:additionalProperty","schema:value"],"required":true,"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:additionalProperty","schema:unitCode"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:additionalProperty","schema:unitText"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.additionalProperty"]},{"path":["schema:validFrom"],"description":"Date the instrument was commissioned (ISO 8601).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:validThrough"],"description":"Date the instrument was decommissioned (ISO 8601). Absent if still operational.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:hasPart"],"description":"Sub-components of this instrument system. Each item is either an inline instrument description or an @id reference.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:relatedLink"],"description":"Links to related resources (manuals, datasheets, calibration records, related instruments).","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:relatedLink","schema:name"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:relatedLink","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:relatedLink","schema:url"],"required":true,"schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:subjectOf"],"description":"Catalog record metadata-about-metadata for this instrument description.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:subjectOf","schema:dateModified"],"description":"Date this metadata record was last modified (ISO 8601).","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:subjectOf","schema:about"],"schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:subjectOf","dcterms:conformsTo"],"description":"Schema or profile this metadata record conforms to.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:contributor","schema:contributor","schema:sameAs"],"description":"other identifiers for the person","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:contributor","schema:contributor","schema:contactPoint"],"description":"restrict to email only. Schema.org allows telephone and postal contacts as well","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:contributor","schema:contributor","schema:contactPoint","schema:email"],"required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:contributor","schema:contributor","schema:affiliation"],"description":"if affiliation is present, value must be a schema:Organization.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:contributor","schema:contributor","schema:alternateName"],"description":"other labels by which the person might be known","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:contributor","schema:contributor","schema:identifier"],"description":"identifier for person, recommend ORCID","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:contributor","schema:contributor","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:contributor","schema:contributor","schema:name"],"description":"string label for person that is meaningful for human users, should format consistently. Recommend 'Family Name, Given name' format.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:identifier","schema:url"],"description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:identifier","schema:value"],"description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:identifier","schema:propertyID"],"description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:hasPart","schema:model"],"schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:hasPart","schema:model","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:hasPart","schema:model","schema:name"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:hasPart","schema:manufacturer"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:hasPart","schema:additionalProperty"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:hasPart","schema:additionalType"],"description":"Component type classification.","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:hasPart","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:hasPart","schema:alternateName"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:hasPart","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]},{"path":["schema:hasPart","schema:name"],"required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.instrument"]}]}